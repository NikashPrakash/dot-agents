{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./schemas/workflow-iter-log.schema.json",
  "title": "dot-agents workflow iteration log entry",
  "description": "Schema for .agents/active/iteration-log/iter-N.yaml (schema_version 2). Top-level git and delegation fields are CLI-owned. Nested impl, verifiers[], and review are role-owned: each `workflow checkpoint --log-to-iter N --role …` merge updates only that role's block. `additionalProperties: false` keeps field names stable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "iteration",
    "date",
    "wave",
    "task_id",
    "impl",
    "verifiers",
    "review"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2,
      "description": "Schema version 2 — role-owned blocks."
    },
    "iteration": {
      "type": "integer",
      "minimum": 1,
      "description": "CLI: monotonically increasing iteration number."
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "CLI: date the checkpoint was written (YYYY-MM-DD)."
    },
    "wave": {
      "type": "string",
      "description": "CLI: active plan ID at checkpoint time."
    },
    "task_id": {
      "type": "string",
      "description": "CLI: active task ID from the delegation contract or checkpoint."
    },
    "commit": {
      "type": "string",
      "description": "CLI: git commit SHA at checkpoint time. Empty string if none.",
      "default": ""
    },
    "files_changed": {
      "type": "integer",
      "minimum": 0,
      "description": "CLI: files changed from git diff --stat HEAD~1.",
      "default": 0
    },
    "lines_added": {
      "type": "integer",
      "minimum": 0,
      "description": "CLI: lines added from git diff --stat HEAD~1.",
      "default": 0
    },
    "lines_removed": {
      "type": "integer",
      "minimum": 0,
      "description": "CLI: lines removed from git diff --stat HEAD~1.",
      "default": 0
    },
    "first_commit": {
      "type": "boolean",
      "description": "CLI: true when HEAD~1 does not exist.",
      "default": false
    },
    "impl": {
      "type": "object",
      "description": "impl-agent / loop-worker contribution. CLI merges AUTO fields; agent-owned fields persist across impl merges.",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "item": { "type": "string", "default": "" },
        "summary": { "type": "string", "default": "" },
        "scope_note": {
          "type": "string",
          "enum": ["on-target", "scope-breach", "partial", ""],
          "default": ""
        },
        "feedback_goal": {
          "type": "string",
          "description": "AUTO from delegation bundle verification.feedback_goal when available.",
          "default": ""
        },
        "retries": { "type": "integer", "minimum": 0, "default": 0 },
        "focused_tests_added": { "type": "integer", "minimum": 0, "default": 0 },
        "focused_tests_pass": {
          "type": ["boolean", "null"],
          "default": null
        },
        "self_assessment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read_loop_state": { "type": "boolean", "default": false },
            "one_item_only": { "type": "boolean", "default": false },
            "committed_after_tests": { "type": "boolean", "default": false },
            "aligned_with_canonical_tasks": { "type": "boolean", "default": false },
            "persisted_via_workflow_commands": {
              "type": "string",
              "default": ""
            },
            "stayed_under_10_files": { "type": "boolean", "default": false },
            "no_destructive_commands": { "type": "boolean", "default": false },
            "scoped_tests_to_write_scope": { "type": "boolean", "default": false },
            "tdd_refresh_performed": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "verifiers": {
      "type": "array",
      "description": "One entry per verifier type that ran this iteration.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9_-]*$",
            "description": "Verifier slug matching <type>.result.yaml stem."
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "partial", "unknown"],
            "description": "AUTO from verification result artifact.",
            "default": "unknown"
          },
          "gate_passed": {
            "type": "boolean",
            "description": "AUTO: true when status is pass.",
            "default": false
          },
          "tests_added": { "type": "integer", "minimum": 0, "default": 0 },
          "tests_total_pass": { "type": ["boolean", "null"], "default": null },
          "scenario_tags": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "retries": { "type": "integer", "minimum": 0, "default": 0 },
          "result_artifact": {
            "type": "string",
            "description": "Repo-relative path to <type>.result.yaml.",
            "default": ""
          },
          "self_assessment": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "tests_positive_and_negative": { "type": "boolean", "default": false },
              "tests_used_sandbox": { "type": "boolean", "default": false },
              "exercised_new_scenario": { "type": "boolean", "default": false },
              "ran_cli_command": { "type": "boolean", "default": false },
              "cli_produced_actionable_feedback": { "type": "string", "default": "" },
              "linked_traces_to_outcomes": { "type": "boolean", "default": false }
            }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "description": "review-agent contribution; AUTO fields parsed from review-decision.yaml when present.",
      "additionalProperties": false,
      "properties": {
        "phase_1_decision": {
          "type": "string",
          "enum": ["accept", "reject", "escalate", ""],
          "default": ""
        },
        "phase_2_decision": {
          "type": "string",
          "enum": ["accept", "reject", "escalate", ""],
          "default": ""
        },
        "overall_decision": {
          "type": "string",
          "enum": ["accept", "reject", "escalate", ""],
          "default": ""
        },
        "failed_gates": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "escalation_reason": { "type": "string", "default": "" },
        "reviewer_notes": { "type": "string", "default": "" },
        "decision_artifact": {
          "type": "string",
          "description": "Repo-relative path to review-decision.yaml.",
          "default": ""
        },
        "verify_record_appended": {
          "type": "boolean",
          "description": "Set when workflow verify record appends audit evidence (future hook).",
          "default": false
        }
      }
    }
  }
}
