#!/usr/bin/env bash
# ralph-pipeline: full E2E orchestration pipeline.
#   Phase 1: ralph-orchestrate  → discovers unblocked tasks, creates bundles
#   Phase 2: ralph-worker       → parallel workers, one per bundle
#   Phase 3: ralph-closeout     → accept merge-backs, advance canonical tasks
#
# Each phase uses role-pure scripts. Orchestrator does not implement.
# Workers do not select tasks. Closeout is separate.
#
# Env vars (forwarded to sub-scripts as appropriate):
#   RALPH_ITERATIONS             worker implementation budget (default 5)
#   RALPH_MAX_PARALLEL_WORKERS   max concurrent workers (default 3)
#   RALPH_AUTO_FANOUT            1 = auto-create bundles (default)
#   RALPH_RUN_PLAN               single id or comma-separated canonical plan scope for completion mode
#   RALPH_DELEGATION_PROMPT_FILE optional: forwarded to ralph-orchestrate (must differ from RALPH_PROJECT_OVERLAY; see D5)
#   RALPH_CLOSEOUT_AUTO          1 = auto-accept merge-backs (default)
#   RALPH_POST_CLOSEOUT_FOLD_BACK_AUDIT  forwarded to ralph-closeout: optional read-only fold-back list per plan after closeout
#   RALPH_ORCHESTRATOR_MODEL     orchestrator-only model override
#   RALPH_CLOSEOUT_MODEL         closeout-review model override
#   RALPH_IMPL_WORKER_MODEL      impl-worker model override
#   RALPH_VERIFIER_WORKER_MODEL  verifier-worker model override
#   RALPH_REVIEW_WORKER_MODEL    review-worker model override
#   RALPH_WORKER_MODEL           generic worker model override
#   RALPH_MODEL                  fallback model override
#   RALPH_ORCHESTRATOR_REASONING_EFFORT  codex-only orchestrator reasoning effort override
#   RALPH_CLOSEOUT_REASONING_EFFORT      codex-only closeout reasoning effort override
#   RALPH_IMPL_WORKER_REASONING_EFFORT   codex-only impl-worker reasoning effort override
#   RALPH_VERIFIER_WORKER_REASONING_EFFORT  codex-only verifier-worker reasoning effort override
#   RALPH_REVIEW_WORKER_REASONING_EFFORT    codex-only review-worker reasoning effort override
#   RALPH_WORKER_REASONING_EFFORT        codex-only generic worker reasoning effort override
#   RALPH_REASONING_EFFORT               codex-only fallback reasoning effort override
#   RALPH_FORCE                  1 = pass -f to agent
#   RALPH_LOG_DIR                override base log directory (subdirs created per phase)
#   RALPH_NO_LOG                 1 = stdout only, no files
#   RALPH_AGENT_OUTPUT_FORMAT    text|json|stream-json (default stream-json)
#   RALPH_ORCHESTRATOR_AGENT_BIN orchestrator-only agent binary override
#   RALPH_CLOSEOUT_AGENT_BIN     closeout-review agent binary override
#   RALPH_IMPL_WORKER_AGENT_BIN      impl-worker agent binary override
#   RALPH_VERIFIER_WORKER_AGENT_BIN  verifier-worker agent binary override
#   RALPH_REVIEW_WORKER_AGENT_BIN    review-worker agent binary override
#   RALPH_WORKER_AGENT_BIN           generic worker agent binary override
#   RALPH_STAGE_RETRY_MAX            max replacement retries per stage for resumable terminal failures (default 2)
#   AGENT_BIN                    fallback agent binary (default: agent)
#   DOT_AGENTS                   dot-agents binary or "go run ..." override
#
# Control plane (dot-agents): fanout creates `.agents/active/verification/<task_id>/` before dispatch;
#   `workflow next --plan <id>[,<id>...]` scopes break checks to the filtered plan set.
#
# Early exits:
#   No unblocked tasks (no RALPH_BUNDLE lines from orchestrate) → message, exit 0
#   Fanout failed → exit 1
#   Worker error → continues to closeout, reports summary
#   Closeout error → exit 1
#
# Metrics: writes .ralph-loop-streams/<run-dir>/metrics.json after completion

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

ORIG_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Run from a temp snapshot so workers can safely edit the repo copies of these
# scripts without corrupting the unread tail of the currently executing shell.
if [[ -z "${RALPH_PIPELINE_SNAPSHOT_DIR:-}" ]]; then
  SNAPSHOT_DIR="$(mktemp -d "${TMPDIR:-/tmp}/ralph-pipeline-snapshot.XXXXXX")"
  cp \
    "$ORIG_SCRIPT_DIR/ralph-pipeline" \
    "$ORIG_SCRIPT_DIR/ralph-orchestrate" \
    "$ORIG_SCRIPT_DIR/ralph-worker" \
    "$ORIG_SCRIPT_DIR/ralph-closeout" \
    "$SNAPSHOT_DIR/"
  [[ -f "$ORIG_SCRIPT_DIR/ralph-review-gate" ]] && cp "$ORIG_SCRIPT_DIR/ralph-review-gate" "$SNAPSHOT_DIR/"
  chmod +x \
    "$SNAPSHOT_DIR/ralph-pipeline" \
    "$SNAPSHOT_DIR/ralph-orchestrate" \
    "$SNAPSHOT_DIR/ralph-worker" \
    "$SNAPSHOT_DIR/ralph-closeout"
  [[ -f "$SNAPSHOT_DIR/ralph-review-gate" ]] && chmod +x "$SNAPSHOT_DIR/ralph-review-gate"
  export RALPH_PIPELINE_SNAPSHOT_DIR="$SNAPSHOT_DIR"
  export RALPH_PIPELINE_SNAPSHOT_OWNER=1
  exec "$SNAPSHOT_DIR/ralph-pipeline" "$@"
fi

SCRIPT_DIR="$RALPH_PIPELINE_SNAPSHOT_DIR"
if [[ "${RALPH_PIPELINE_SNAPSHOT_OWNER:-0}" == "1" ]]; then
  trap 'rm -rf "$RALPH_PIPELINE_SNAPSHOT_DIR" 2>/dev/null || true' EXIT
fi

RALPH_ORCHESTRATE="$SCRIPT_DIR/ralph-orchestrate"
RALPH_WORKER="$SCRIPT_DIR/ralph-worker"
RALPH_CLOSEOUT="$SCRIPT_DIR/ralph-closeout"
RALPH_REVIEW_GATE="$SCRIPT_DIR/ralph-review-gate"

for s in "$RALPH_ORCHESTRATE" "$RALPH_WORKER" "$RALPH_CLOSEOUT"; do
  [[ -x "$s" ]] || { echo "error: script not found or not executable: $s" >&2; exit 1; }
done

# Build dot-agents helper for stage expansion
DOT_AGENTS_CMD=()
if [[ -n "${DOT_AGENTS:-}" ]]; then
  # shellcheck disable=SC2206
  DOT_AGENTS_CMD=( $DOT_AGENTS )
elif [[ -f "$REPO_ROOT/cmd/dot-agents/main.go" ]]; then
  DOT_AGENTS_CMD=(go run ./cmd/dot-agents)
elif command -v dot-agents >/dev/null 2>&1; then
  DOT_AGENTS_CMD=(dot-agents)
fi

RUN_TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
if [[ "${RALPH_NO_LOG:-0}" == "1" ]]; then
  BASE_LOG_DIR=""
elif [[ -n "${RALPH_LOG_DIR:-}" ]]; then
  BASE_LOG_DIR="$RALPH_LOG_DIR"
else
  BASE_LOG_DIR="$REPO_ROOT/.ralph-loop-streams/run-${RUN_TIMESTAMP}"
fi

[[ -n "$BASE_LOG_DIR" ]] && mkdir -p "$BASE_LOG_DIR"

parse_plan_scope() {
  local raw="${1:-}"
  local -a plans=()
  local entry trimmed

  raw="${raw#./}"
  IFS=',' read -r -a plans <<< "$raw"
  for entry in "${plans[@]}"; do
    trimmed="${entry#"${entry%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -n "$trimmed" ]] && printf '%s\n' "$trimmed"
  done
}

plan_is_in_scope() {
  local plan_id="$1"
  [[ -z "${RALPH_RUN_PLAN:-}" ]] && return 0
  local scope
  while IFS= read -r scope; do
    [[ "$scope" == "$plan_id" ]] && return 0
  done < <(parse_plan_scope "$RALPH_RUN_PLAN")
  return 1
}

describe_worker_exit_code() {
  local rc="$1"
  case "$rc" in
    34) printf '%s' "review_gate_rejected" ;;
    35) printf '%s' "planning_required" ;;
    32) printf '%s' "usage_limit" ;;
    33) printf '%s' "workspace_permissions" ;;
    *) printf '%s' "error" ;;
  esac
}

split_bin_candidates() {
  local raw="${1:-}"
  local part trimmed
  [[ -n "${raw//[[:space:]]/}" ]] || return 0
  while :; do
    if [[ "$raw" == *,* ]]; then
      part="${raw%%,*}"
      raw="${raw#*,}"
    else
      part="$raw"
      raw=""
    fi
    trimmed="${part#"${part%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -n "$trimmed" ]] && printf '%s\n' "$trimmed"
    [[ -z "$raw" ]] && break
  done
}

collect_stage_agent_bins() {
  local stage_role="$1"
  local role_bins=""
  local generic_bins="${RALPH_WORKER_AGENT_BIN:-}"
  local fallback_bins="${AGENT_BIN:-}"
  local candidate seen_bins="|"

  case "$stage_role" in
    impl) role_bins="${RALPH_IMPL_WORKER_AGENT_BIN:-}" ;;
    verifier) role_bins="${RALPH_VERIFIER_WORKER_AGENT_BIN:-}" ;;
    review) role_bins="${RALPH_REVIEW_WORKER_AGENT_BIN:-}" ;;
    *) role_bins="" ;;
  esac

  while IFS= read -r candidate; do
    [[ -z "$candidate" ]] && continue
    [[ "$seen_bins" == *"|${candidate}|"* ]] && continue
    seen_bins="${seen_bins}${candidate}|"
    printf '%s\n' "$candidate"
  done < <(
    split_bin_candidates "$role_bins"
    split_bin_candidates "$generic_bins"
    split_bin_candidates "$fallback_bins"
    printf '%s\n' "agent"
  )
}

stage_role_from_stage_line() {
  local stage_line="$1"
  if [[ "$stage_line" == verifier:* ]]; then
    printf '%s' "verifier"
  elif [[ "$stage_line" == "impl" ]]; then
    printf '%s' "impl"
  elif [[ "$stage_line" == "review" ]]; then
    printf '%s' "review"
  else
    printf '%s' "worker"
  fi
}

write_stage_metrics() {
  local stage_dir="$1"
  local stage_line="$2"
  local stage_role="$3"
  [[ -n "$stage_dir" && -d "$stage_dir" ]] || return 0

  python3 - "$stage_dir" "$stage_line" "$stage_role" <<'PY'
import json
import sys
from pathlib import Path

stage_dir = Path(sys.argv[1])
stage_line = sys.argv[2]
stage_role = sys.argv[3]

def read_env(path: Path):
    data = {}
    if not path.exists():
        return data
    for raw in path.read_text(encoding="utf-8").splitlines():
        if "=" not in raw:
            continue
        key, value = raw.split("=", 1)
        data[key.strip()] = value.strip()
    return data

def parse_int(value):
    try:
        return int(value)
    except Exception:
        return 0

def attempt_index(path: Path):
    try:
        return int(path.name.split("-", 1)[1])
    except Exception:
        return 0

attempts = []
totals = {
    "attempt_count": 0,
    "iterations": 0,
    "input_tokens": 0,
    "output_tokens": 0,
    "cache_read_tokens": 0,
    "tool_uses": 0,
    "duration_ms": 0,
}

for attempt_dir in sorted((p for p in stage_dir.iterdir() if p.is_dir() and p.name.startswith("attempt-")), key=attempt_index):
    status = read_env(attempt_dir / "attempt-status.env")
    context = read_env(attempt_dir / "worker-context.env")

    iter_files = sorted(attempt_dir.glob("worker-iter-*.ndjson"))
    fallback_files = []
    if not iter_files:
        fallback_files.extend(sorted(attempt_dir.glob("worker-iter-*.json")))
        fallback_files.extend(sorted(attempt_dir.glob("worker-iter-*.txt")))
    iteration_count = len(iter_files) if iter_files else len(fallback_files)

    input_tokens = 0
    output_tokens = 0
    cache_read_tokens = 0
    tool_uses = 0
    duration_ms = 0

    for ndjson in iter_files:
        for raw in ndjson.read_text(encoding="utf-8").splitlines():
            raw = raw.strip()
            if not raw:
                continue
            try:
                data = json.loads(raw)
            except Exception:
                continue
            if data.get("type") == "result":
                usage = data.get("usage", {})
                input_tokens += int(usage.get("inputTokens", 0) or 0)
                output_tokens += int(usage.get("outputTokens", 0) or 0)
                cache_read_tokens += int(usage.get("cacheReadTokens", 0) or 0)
                duration_ms += int(data.get("duration_ms", 0) or 0)
            if data.get("type") == "tool_call" and data.get("subtype") == "started":
                tool_uses += 1

    attempt = {
        "attempt": parse_int(status.get("attempt", attempt_dir.name.split("-", 1)[-1])),
        "agent_bin": status.get("agent_bin", context.get("resolved_agent_bin", "")),
        "exit_code": parse_int(status.get("exit_code", "0")),
        "exit_label": status.get("exit_label", ""),
        "completed": status.get("completed", "false").lower() == "true",
        "iterations": iteration_count,
        "input_tokens": input_tokens,
        "output_tokens": output_tokens,
        "cache_read_tokens": cache_read_tokens,
        "tool_uses": tool_uses,
        "duration_ms": duration_ms,
    }
    attempts.append(attempt)
    totals["attempt_count"] += 1
    totals["iterations"] += iteration_count
    totals["input_tokens"] += input_tokens
    totals["output_tokens"] += output_tokens
    totals["cache_read_tokens"] += cache_read_tokens
    totals["tool_uses"] += tool_uses
    totals["duration_ms"] += duration_ms

out = {
    "schema_version": 1,
    "stage": stage_line,
    "stage_role": stage_role,
    "attempts": attempts,
    "totals": totals,
    "final_exit_label": attempts[-1]["exit_label"] if attempts else "unknown",
    "completed": attempts[-1]["completed"] if attempts else False,
}

(stage_dir / "stage-metrics.json").write_text(json.dumps(out, indent=2) + "\n", encoding="utf-8")
PY
}

scoped_completion_state() {
  local plan_scope="${1:-}"
  [[ -z "$plan_scope" ]] && return 1
  local complete_json
  set +e
  complete_json="$( (cd "$REPO_ROOT" && "${DOT_AGENTS_CMD[@]}" workflow complete --json --plan "$plan_scope") 2>/dev/null )"
  local rc=$?
  set -e
  if [[ $rc -ne 0 ]]; then
    return 2
  fi
  complete_json="${complete_json//$'\n'/}"
  [[ -n "$complete_json" && "$complete_json" != "null" ]] || return 1
  printf '%s' "$complete_json" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(2)
print(data.get('state', ''))
" 2>/dev/null
}

run_pipeline_pass() {
  echo "=== ralph-pipeline: starting run ${RUN_TIMESTAMP} ===" >&2
  pipeline_stage_retry_max="${RALPH_STAGE_RETRY_MAX:-2}"
  [[ "$pipeline_stage_retry_max" =~ ^[0-9]+$ ]] || pipeline_stage_retry_max=2

  # Phase 1: Orchestrate — collect RALPH_BUNDLE lines
  echo "=== ralph-pipeline: phase 1 — orchestrate ===" >&2

ORCH_LOG_DIR="${BASE_LOG_DIR:+${BASE_LOG_DIR}/orchestrate}"
[[ -n "$ORCH_LOG_DIR" ]] && mkdir -p "$ORCH_LOG_DIR"

orch_output_file="$(mktemp "${TMPDIR:-/tmp}/ralph-orch-output.XXXXXX")"

export RALPH_NO_LOG="${RALPH_NO_LOG:-0}"
export RALPH_LOG_DIR="${ORCH_LOG_DIR:-}"
export RALPH_MAX_PARALLEL_WORKERS="${RALPH_MAX_PARALLEL_WORKERS:-3}"
export RALPH_AUTO_FANOUT="${RALPH_AUTO_FANOUT:-1}"
export RALPH_MODEL="${RALPH_MODEL:-}"
export RALPH_FORCE="${RALPH_FORCE:-0}"
export RALPH_AGENT_OUTPUT_FORMAT="${RALPH_AGENT_OUTPUT_FORMAT:-stream-json}"
export AGENT_BIN="${AGENT_BIN:-agent}"
export DOT_AGENTS="${DOT_AGENTS:-}"

orch_rc=0
set +e
"$RALPH_ORCHESTRATE" 2>&1 | tee "$orch_output_file" >&2
orch_rc=${PIPESTATUS[0]}
set -e
if [[ $orch_rc -ne 0 ]]; then
  echo "error: ralph-orchestrate failed (exit $orch_rc)" >&2
  return 1
fi

# Parse RALPH_BUNDLE: lines from orchestrator output
BUNDLES=()
while IFS= read -r line; do
  if [[ "$line" == RALPH_BUNDLE:* ]]; then
    bundle_path="${line#RALPH_BUNDLE: }"
    bundle_path="${bundle_path## }"
    [[ -f "$bundle_path" ]] && BUNDLES+=( "$bundle_path" )
  fi
done <"$orch_output_file"

# Fallback: pick up delegation bundles only when there is still an active delegation
# contract for the bundle's task_id. Otherwise stale del-*.yaml files from completed
# runs would respawn workers on no-op orchestrate passes.
if [[ ${#BUNDLES[@]} -eq 0 && -d "$REPO_ROOT/.agents/active/delegation-bundles" ]]; then
  for f in "$REPO_ROOT/.agents/active/delegation-bundles"/del-*.yaml; do
    [[ -f "$f" ]] || continue
    tid="$(python3 - "$f" <<'PY'
import re, sys
try:
    text = open(sys.argv[1], encoding="utf-8").read()
    m = re.search(r"^task_id:\s*(.+)", text, re.M)
    print(m.group(1).strip().strip('"') if m else "")
except Exception:
    pass
    PY
)"
    [[ -z "$tid" ]] && continue
    plan_id="$(python3 - "$f" <<'PY'
import re, sys
try:
    text = open(sys.argv[1], encoding="utf-8").read()
    m = re.search(r"^(?:parent_)?plan_id:\s*(.+)", text, re.M)
    print(m.group(1).strip().strip('"') if m else "")
except Exception:
    pass
PY
)"
    [[ -z "$plan_id" ]] && continue
    if ! plan_is_in_scope "$plan_id"; then
      continue
    fi
    [[ -f "$REPO_ROOT/.agents/active/delegation/${tid}.yaml" ]] || continue
    BUNDLES+=( "$f" )
  done
  [[ ${#BUNDLES[@]} -gt 0 ]] && echo "ralph-pipeline: using ${#BUNDLES[@]} existing bundle(s) with active delegations (delegation-bundles/ fallback)" >&2
fi

# Also emit the orchestrator output to stdout
cat "$orch_output_file"
rm -f "$orch_output_file" 2>/dev/null || true

if [[ ${#BUNDLES[@]} -eq 0 ]]; then
  echo "ralph-pipeline: no bundles created — no unblocked tasks to work on" >&2
  # Write minimal metrics
  if [[ -n "$BASE_LOG_DIR" ]]; then
    cat >"$BASE_LOG_DIR/metrics.json" <<EOF
{
  "run_id": "${RUN_TIMESTAMP}",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "worker_mode": "script",
  "bundles_created": 0,
  "workers_spawned": 0,
  "worker_iterations": {},
  "merge_back_status": {},
  "persisted_via_workflow_commands": {},
  "context_tokens_approx": null
}
EOF
  fi
  if [[ -n "${RALPH_RUN_PLAN:-}" ]]; then
    echo "error: scoped completion mode expected actionable work for plan(s): ${RALPH_RUN_PLAN}" >&2
    return 1
  fi
  return 0
fi

echo "ralph-pipeline: ${#BUNDLES[@]} bundle(s) created — spawning workers" >&2

# Phase 2: Workers — staged pipeline per bundle, bundles run in parallel
echo "=== ralph-pipeline: phase 2 — staged workers (parallel across bundles) ===" >&2

WORKER_LOG_DIR="${BASE_LOG_DIR:+${BASE_LOG_DIR}/workers}"
[[ -n "$WORKER_LOG_DIR" ]] && mkdir -p "$WORKER_LOG_DIR"

worker_pids=()
worker_logs=()
worker_bundle_keys=()

for bundle_path in "${BUNDLES[@]}"; do
  bundle_base="$(basename "$bundle_path" .yaml)"
  wlog="${WORKER_LOG_DIR:+${WORKER_LOG_DIR}/${bundle_base}}"
  [[ -n "$wlog" ]] && mkdir -p "$wlog"

  echo "ralph-pipeline: spawning staged bundle execution for $(basename "$bundle_path")" >&2
  (
    export RALPH_ITERATIONS="${RALPH_ITERATIONS:-5}"

    # Expand stages deterministically via dot-agents (impl → verifier:X … → review)
    stages_text=""
    if [[ ${#DOT_AGENTS_CMD[@]} -gt 0 ]]; then
      stages_text="$( (cd "$REPO_ROOT" && "${DOT_AGENTS_CMD[@]}" workflow bundle stages "$bundle_path") 2>/dev/null)" || stages_text=""
    fi

    if [[ -z "$stages_text" ]]; then
      # dot-agents unavailable or no stage metadata — fall back to single loop-worker
      echo "ralph-pipeline: warning: could not expand stages for $(basename "$bundle_path"), falling back to loop-worker" >&2
      export RALPH_LOG_DIR="${wlog:-}"
      "$RALPH_WORKER" --bundle "$bundle_path"
      exit $?
    fi

    # Run each stage sequentially; give each stage its own log subdir
    stage_rc=0
    stage_retry_max="$pipeline_stage_retry_max"
    bundle_retry_attempts=0
    bundle_retry_recovered=0
    bundle_last_terminal_failure="none"
    replacement_retry_log="${wlog:+${wlog}/replacement-retry.log}"
    replacement_retry_env="${wlog:+${wlog}/replacement-retry.env}"
    [[ -n "$replacement_retry_log" ]] && : > "$replacement_retry_log"
    while IFS= read -r stage_line; do
      [[ -z "$stage_line" ]] && continue
      stage_log="${wlog:+${wlog}/stage-${stage_line//:/+}}"
      [[ -n "$stage_log" ]] && mkdir -p "$stage_log"

      stage_role="$(stage_role_from_stage_line "$stage_line")"
      stage_bins=()
      while IFS= read -r stage_bin; do
        [[ -n "$stage_bin" ]] && stage_bins+=( "$stage_bin" )
      done < <(collect_stage_agent_bins "$stage_role")

      stage_bin_index=0
      stage_retries_used=0
      stage_completed=0
      stage_usage_limit_exhausted=0
      while [[ $stage_completed -eq 0 ]]; do
        if [[ $stage_bin_index -ge ${#stage_bins[@]} ]]; then
          echo "ralph-pipeline: stage ${stage_line} has no remaining fallback agent bin candidates" >&2
          bundle_last_terminal_failure="usage_limit"
          stage_usage_limit_exhausted=1
          stage_rc=32
          break
        fi

        stage_bin="${stage_bins[$stage_bin_index]}"
        attempt_no=$((stage_retries_used + 1))
        stage_attempt_log="${stage_log:+${stage_log}/attempt-${attempt_no}}"
        [[ -n "$stage_attempt_log" ]] && mkdir -p "$stage_attempt_log"
        export RALPH_LOG_DIR="${stage_attempt_log:-}"
        export RALPH_WORKER_AGENT_BIN_OVERRIDE="$stage_bin"
        echo "ralph-pipeline: [$(basename "$bundle_path")] stage ${stage_line} attempt ${attempt_no}/$((stage_retry_max + 1)) (agent_bin=${stage_bin})" >&2

        set +e
        if [[ "$stage_line" == verifier:* ]]; then
          vtype="${stage_line#verifier:}"
          "$RALPH_WORKER" --bundle "$bundle_path" --stage verifier --verifier-type "$vtype"
        else
          "$RALPH_WORKER" --bundle "$bundle_path" --stage "$stage_line"
        fi
        rc=$?
        set -e
        unset RALPH_WORKER_AGENT_BIN_OVERRIDE

        exit_label="$(describe_worker_exit_code "$rc")"
        if [[ $rc -eq 0 ]]; then
          exit_label="success"
        fi
        if [[ -n "${stage_attempt_log:-}" ]]; then
          {
            echo "attempt=${attempt_no}"
            echo "stage=${stage_line}"
            echo "stage_role=${stage_role}"
            echo "agent_bin=${stage_bin}"
            echo "exit_code=${rc}"
            echo "exit_label=${exit_label}"
            if [[ $rc -eq 0 ]]; then
              echo "completed=true"
            else
              echo "completed=false"
            fi
          } > "${stage_attempt_log}/attempt-status.env"
        fi

        if [[ $rc -eq 0 ]]; then
          if [[ $stage_retries_used -gt 0 ]]; then
            (( bundle_retry_recovered++ )) || true
            [[ -n "$replacement_retry_log" ]] && {
              printf 'stage=%s outcome=recovered retries=%d final_bin=%s\n' \
                "$stage_line" "$stage_retries_used" "$stage_bin" >> "$replacement_retry_log"
            }
          fi
          stage_completed=1
          continue
        fi

        echo "ralph-pipeline: stage ${stage_line} exited non-zero (status $rc: ${exit_label})" >&2

        if [[ $rc -eq 32 ]]; then
          bundle_last_terminal_failure="usage_limit"
          if [[ $stage_retries_used -ge $stage_retry_max ]]; then
            stage_usage_limit_exhausted=1
            [[ -n "$replacement_retry_log" ]] && {
              printf 'stage=%s outcome=retry_exhausted retries=%d last_bin=%s reason=usage_limit\n' \
                "$stage_line" "$stage_retries_used" "$stage_bin" >> "$replacement_retry_log"
            }
            stage_rc=$rc
            break
          fi
          next_index=$((stage_bin_index + 1))
          if [[ $next_index -ge ${#stage_bins[@]} ]]; then
            stage_usage_limit_exhausted=1
            [[ -n "$replacement_retry_log" ]] && {
              printf 'stage=%s outcome=no_fallback retries=%d last_bin=%s reason=usage_limit\n' \
                "$stage_line" "$stage_retries_used" "$stage_bin" >> "$replacement_retry_log"
            }
            stage_rc=$rc
            break
          fi
          next_bin="${stage_bins[$next_index]}"
          stage_bin_index=$next_index
          (( stage_retries_used++ )) || true
          (( bundle_retry_attempts++ )) || true
          echo "ralph-pipeline: resumable terminal failure usage_limit in stage ${stage_line}; replacement retry ${stage_retries_used}/${stage_retry_max} using fallback agent_bin=${next_bin}" >&2
          [[ -n "$replacement_retry_log" ]] && {
            printf 'stage=%s outcome=retrying retry=%d/%d failed_bin=%s next_bin=%s reason=usage_limit\n' \
              "$stage_line" "$stage_retries_used" "$stage_retry_max" "$stage_bin" "$next_bin" >> "$replacement_retry_log"
          }
          continue
        fi

        if [[ $rc -eq 33 ]]; then
          bundle_last_terminal_failure="workspace_permissions"
          [[ -n "$replacement_retry_log" ]] && {
            printf 'stage=%s outcome=hard_stop retries=%d last_bin=%s reason=workspace_permissions\n' \
              "$stage_line" "$stage_retries_used" "$stage_bin" >> "$replacement_retry_log"
          }
        fi
        stage_rc=$rc
        break
      done

      write_stage_metrics "${stage_log:-}" "$stage_line" "$stage_role"

      if [[ $stage_completed -eq 0 ]]; then
        if [[ $stage_usage_limit_exhausted -eq 1 ]]; then
          echo "ralph-pipeline: stage ${stage_line} hit usage_limit with no remaining retries/fallback bins; stopping bundle" >&2
        fi
        break
      fi
    done <<<"$stages_text"

    if [[ -n "$replacement_retry_env" ]]; then
      {
        echo "replacement_retry_attempts=${bundle_retry_attempts}"
        echo "replacement_retry_recovered=${bundle_retry_recovered}"
        echo "replacement_retry_last_failure=${bundle_last_terminal_failure}"
      } > "$replacement_retry_env"
    fi

    if [[ $stage_rc -ne 0 ]]; then
      exit $stage_rc
    fi

    # Post-staged review gate (p7)
    gate_rc=0
    if [[ -x "$RALPH_REVIEW_GATE" ]]; then
      export RALPH_LOG_DIR=""
      "$RALPH_REVIEW_GATE" --bundle "$bundle_path" || gate_rc=$?
      if [[ $gate_rc -eq 2 ]]; then
        echo "ralph-pipeline: review gate blocked closeout for $(basename "$bundle_path") (rejected)" >&2
        exit 34
      fi
      if [[ $gate_rc -eq 3 ]]; then
        echo "ralph-pipeline: review gate blocked closeout for $(basename "$bundle_path") (planning required)" >&2
        exit 35
      fi
      if [[ $gate_rc -ne 0 ]]; then
        echo "ralph-pipeline: review gate error (exit $gate_rc) for $(basename "$bundle_path")" >&2
        exit "$gate_rc"
      fi
    fi

    exit $stage_rc
  ) &
  pid=$!
  worker_pids+=("$pid")
  worker_logs+=("${wlog:-}")
  worker_bundle_keys+=("$bundle_path")
done

# Wait for all workers
worker_errors=0
review_gate_rejections=0
review_gate_pauses=0
usage_limit_hard_stops=0
workspace_permissions_hard_stops=0
for i in "${!worker_bundle_keys[@]}"; do
  bundle_path="${worker_bundle_keys[$i]}"
  pid="${worker_pids[$i]}"
  if wait "$pid"; then
    echo "ralph-pipeline: worker for $(basename "$bundle_path") completed" >&2
  else
    rc=$?
    echo "ralph-pipeline: worker for $(basename "$bundle_path") exited with $(describe_worker_exit_code "$rc") (status $rc, pid=$pid)" >&2
    if [[ $rc -eq 34 ]]; then
      (( review_gate_rejections++ )) || true
    fi
    if [[ $rc -eq 35 ]]; then
      (( review_gate_pauses++ )) || true
    fi
    if [[ $rc -eq 32 ]]; then
      (( usage_limit_hard_stops++ )) || true
    fi
    if [[ $rc -eq 33 ]]; then
      (( workspace_permissions_hard_stops++ )) || true
    fi
    (( worker_errors++ )) || true
  fi
done

if [[ $review_gate_rejections -gt 0 || $review_gate_pauses -gt 0 ]]; then
  if [[ $review_gate_rejections -gt 0 ]]; then
    echo "ralph-pipeline: ${review_gate_rejections} bundle(s) were rejected by the review gate — skipping closeout" >&2
  fi
  if [[ $review_gate_pauses -gt 0 ]]; then
    echo "ralph-pipeline: ${review_gate_pauses} bundle(s) require planning or human review — skipping closeout" >&2
  fi
  return 1
fi

if [[ $usage_limit_hard_stops -gt 0 || $workspace_permissions_hard_stops -gt 0 ]]; then
  [[ $usage_limit_hard_stops -gt 0 ]] && echo "ralph-pipeline: ${usage_limit_hard_stops} bundle(s) stopped after usage_limit retry exhaustion — skipping closeout" >&2
  [[ $workspace_permissions_hard_stops -gt 0 ]] && echo "ralph-pipeline: ${workspace_permissions_hard_stops} bundle(s) hit non-resumable workspace_permissions — skipping closeout" >&2
  return 1
fi

if [[ $worker_errors -gt 0 ]]; then
  echo "ralph-pipeline: $worker_errors worker(s) failed — continuing to closeout" >&2
fi

# Phase 3: Closeout
echo "=== ralph-pipeline: phase 3 — closeout ===" >&2

CLOSEOUT_LOG_DIR="${BASE_LOG_DIR:+${BASE_LOG_DIR}/closeout}"
[[ -n "$CLOSEOUT_LOG_DIR" ]] && mkdir -p "$CLOSEOUT_LOG_DIR"

export RALPH_LOG_DIR="${CLOSEOUT_LOG_DIR:-}"
export RALPH_CLOSEOUT_AUTO="${RALPH_CLOSEOUT_AUTO:-1}"
export RALPH_POST_CLOSEOUT_FOLD_BACK_AUDIT="${RALPH_POST_CLOSEOUT_FOLD_BACK_AUDIT:-0}"

if ! "$RALPH_CLOSEOUT"; then
  echo "error: ralph-closeout failed" >&2
  return 1
fi

# Write metrics
if [[ -n "$BASE_LOG_DIR" ]]; then
  merge_back_entries=""
  worker_iter_entries=""
  persisted_entries=""
  token_entries=""
  stage_metrics_entries=""
  retry_attempt_entries=""
  retry_recovered_entries=""
  retry_failure_entries=""
  retry_total_attempts=0
  retry_total_recovered=0

  for bundle_path in "${BUNDLES[@]}"; do
    bundle_base="$(basename "$bundle_path" .yaml)"

    # Derive task_id: parse from bundle YAML (plan_id / task_id at top level)
    task_id="$(python3 -c "
import re, sys
text = open('${bundle_path}').read()
m = re.search(r'^task_id:\s*(.+)', text, re.M)
print(m.group(1).strip() if m else '')
" 2>/dev/null || true)"
    [[ -z "$task_id" ]] && continue

    # Aggregate per-stage metrics from stage-owned manifests.
    wlog="${WORKER_LOG_DIR:+${WORKER_LOG_DIR}/${bundle_base}}"
    iter_count=0
    tokens_in=0; tokens_out=0; tokens_cache_read=0; tool_uses=0; duration_ms=0
    stage_metrics_json='{"stages":[],"totals":{"attempt_count":0,"iterations":0,"input_tokens":0,"output_tokens":0,"cache_read_tokens":0,"tool_uses":0,"duration_ms":0}}'
    if [[ -n "$wlog" && -d "$wlog" ]]; then
      stage_metrics_payload="$(python3 - "$wlog" <<'PY'
import json
import sys
from pathlib import Path

wlog = Path(sys.argv[1])
stage_files = sorted(wlog.glob("stage-*/stage-metrics.json"))
stages = []
totals = {
    "attempt_count": 0,
    "iterations": 0,
    "input_tokens": 0,
    "output_tokens": 0,
    "cache_read_tokens": 0,
    "tool_uses": 0,
    "duration_ms": 0,
}

for path in stage_files:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    stages.append(data)
    stage_totals = data.get("totals", {})
    for key in totals:
        totals[key] += int(stage_totals.get(key, 0) or 0)

payload = {"stages": stages, "totals": totals}
print("\t".join([
    str(totals["iterations"]),
    str(totals["input_tokens"]),
    str(totals["output_tokens"]),
    str(totals["cache_read_tokens"]),
    str(totals["tool_uses"]),
    str(totals["duration_ms"]),
    json.dumps(payload, separators=(",", ":")),
]))
PY
)"
      IFS=$'\t' read -r iter_count tokens_in tokens_out tokens_cache_read tool_uses duration_ms stage_metrics_json <<< "$stage_metrics_payload"
    fi

    # merge-back status + persisted check
    mb="$REPO_ROOT/.agents/active/merge-back/${task_id}.md"
    hist_mb="$REPO_ROOT/.agents/history/"*"/delegate-merge-back-archive/"*"/${task_id}/merge-back.md"
    if [[ -f "$mb" ]]; then
      mb_status="present"
      persisted="$(python3 -c "
import re, sys
t=open('$mb').read()
m=re.search(r'persisted_via_workflow_commands:\s*(\S+)', t)
print(m.group(1) if m else 'unknown')
" 2>/dev/null || echo 'unknown')"
    else
      mb_status="missing"
      persisted="no"
    fi

    context_tokens=$((tokens_in + tokens_cache_read))
    [[ $context_tokens -eq 0 ]] && context_tokens_val="null" || context_tokens_val="$context_tokens"

    [[ -n "$merge_back_entries" ]] && merge_back_entries+=","
    merge_back_entries+="\"${task_id}\": \"${mb_status}\""

    [[ -n "$worker_iter_entries" ]] && worker_iter_entries+=","
    worker_iter_entries+="\"${task_id}\": ${iter_count}"

    [[ -n "$persisted_entries" ]] && persisted_entries+=","
    persisted_entries+="\"${task_id}\": \"${persisted}\""

    [[ -n "$token_entries" ]] && token_entries+=","
    token_entries+="\"${task_id}\": {\"input_tokens\": ${tokens_in}, \"output_tokens\": ${tokens_out}, \"cache_read_tokens\": ${tokens_cache_read}, \"tool_uses\": ${tool_uses}, \"duration_ms\": ${duration_ms}}"

    [[ -n "$stage_metrics_entries" ]] && stage_metrics_entries+=","
    stage_metrics_entries+="\"${task_id}\": ${stage_metrics_json}"

    retry_env="${WORKER_LOG_DIR:+${WORKER_LOG_DIR}/${bundle_base}/replacement-retry.env}"
    retry_attempts=0
    retry_recovered=0
    retry_last_failure="none"
    if [[ -n "$retry_env" && -f "$retry_env" ]]; then
      retry_attempts="$(awk -F= '/^replacement_retry_attempts=/{print $2}' "$retry_env" | tail -1)"
      retry_recovered="$(awk -F= '/^replacement_retry_recovered=/{print $2}' "$retry_env" | tail -1)"
      retry_last_failure="$(awk -F= '/^replacement_retry_last_failure=/{print $2}' "$retry_env" | tail -1)"
      [[ "$retry_attempts" =~ ^[0-9]+$ ]] || retry_attempts=0
      [[ "$retry_recovered" =~ ^[0-9]+$ ]] || retry_recovered=0
      [[ -n "$retry_last_failure" ]] || retry_last_failure="none"
    fi
    retry_total_attempts=$((retry_total_attempts + retry_attempts))
    retry_total_recovered=$((retry_total_recovered + retry_recovered))
    [[ -n "$retry_attempt_entries" ]] && retry_attempt_entries+=","
    retry_attempt_entries+="\"${task_id}\": ${retry_attempts}"
    [[ -n "$retry_recovered_entries" ]] && retry_recovered_entries+=","
    retry_recovered_entries+="\"${task_id}\": ${retry_recovered}"
    [[ -n "$retry_failure_entries" ]] && retry_failure_entries+=","
    retry_failure_entries+="\"${task_id}\": \"${retry_last_failure}\""
  done

  merge_back_status="{${merge_back_entries}}"
  worker_iterations="{${worker_iter_entries}}"
  persisted_via="${persisted_entries:-}"
  token_detail="${token_entries:-}"
  stage_metrics="${stage_metrics_entries:-}"

  cat >"$BASE_LOG_DIR/metrics.json" <<EOF
{
  "run_id": "${RUN_TIMESTAMP}",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "worker_mode": "script",
  "bundles_created": ${#BUNDLES[@]},
  "workers_spawned": ${#BUNDLES[@]},
  "worker_iterations": ${worker_iterations},
  "merge_back_status": ${merge_back_status},
  "persisted_via_workflow_commands": {${persisted_via}},
  "replacement_retry": {
    "max_per_stage": ${pipeline_stage_retry_max},
    "total_attempts": ${retry_total_attempts},
    "recovered": ${retry_total_recovered},
    "task_attempts": {${retry_attempt_entries}},
    "task_recovered": {${retry_recovered_entries}},
    "task_last_failure": {${retry_failure_entries}}
  },
  "stage_metrics": {${stage_metrics}},
  "token_detail": {${token_detail}},
  "context_tokens_approx": null
}
EOF
  echo "ralph-pipeline: metrics written to $BASE_LOG_DIR/metrics.json" >&2
fi

if [[ $worker_errors -gt 0 ]]; then
  echo "ralph-pipeline: done with $worker_errors worker error(s)" >&2
  return 1
fi

echo "ralph-pipeline: done." >&2
}

if [[ -n "${RALPH_RUN_PLAN:-}" ]]; then
  while true; do
    completion_state="$(scoped_completion_state "$RALPH_RUN_PLAN")"
    probe_rc=$?
    if [[ $probe_rc -eq 2 ]]; then
      echo "error: scoped completion break check failed for plan(s): ${RALPH_RUN_PLAN}" >&2
      exit 1
    fi
    if [[ $probe_rc -ne 0 ]]; then
      echo "error: scoped completion probe returned no state for plan(s): ${RALPH_RUN_PLAN}" >&2
      exit 1
    fi
    case "$completion_state" in
      actionable)
        run_pipeline_pass || exit $?
        ;;
      locked)
        echo "ralph-pipeline: scoped completion locked for plan(s): ${RALPH_RUN_PLAN}" >&2
        exit 0
        ;;
      paused)
        echo "ralph-pipeline: scoped completion paused for plan(s): ${RALPH_RUN_PLAN}" >&2
        exit 0
        ;;
      drained)
        echo "ralph-pipeline: scoped completion mode drained for plan(s): ${RALPH_RUN_PLAN}" >&2
        exit 0
        ;;
      *)
        echo "error: scoped completion probe returned unknown state $completion_state for plan(s): ${RALPH_RUN_PLAN}" >&2
        exit 1
        ;;
    esac
  done
fi

run_pipeline_pass
