{
  "$schema": "https://dot-agents.dev/schemas/config.json",
  "version": 1,
  "defaults": {
    "agent": "cursor"
  },
  "projects": {},
  "agents": {
    "cursor": {
      "enabled": true,
      "version": null
    },
    "claude": {
      "enabled": true,
      "version": null
    },
    "codex": {
      "enabled": true,
      "version": null
    },
    "opencode": {
      "enabled": false,
      "version": null
    },
    "copilot": {
      "enabled": true,
      "version": null
    }
  },
  "features": {
    "tasks": false,
    "history": false,
    "sync": false
  },
  "history": {
    "format": "jsonl",
    "retention_days": 90
  },
  "notifications": {
    "on_migration": true,
    "on_conflict": true
  }
}