{
  "$schema": "https://dot-agents.dev/schemas/agentsrc.json",
  "agents": [
    "test-runner",
    "verifier",
    "loop-worker"
  ],
  "app_type_verifier_map": {
    "go-cli": [
      "unit"
    ]
  },
