    "refreshedAt": "2026-04-20T22:34:20Z"
  },
  "rules": [
    "global",
    "project"
  ],
  "settings": false,
  "skills": [
    "agent-handoff",
    "agent-start",
    "build-graph",
    "create-subagent",
    "gh-fix-ci",
    "playwright",
    "review-delta",
    "review-pr",
    "self-review",
    "skill-architect",
    "split-reviewable-commits",
    "delegation-lifecycle",
    "iteration-close",
    "loop-worker",
    "orchestrator-session-start",
    "plan-wave-picker",
    "platform-docs-refresh",
    "provider-consumer-pair"
